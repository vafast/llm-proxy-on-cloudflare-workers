# 复制为 .env.development 或 .env.production 后填写

# 代理鉴权（必填，非 DEV 模式）
PROXY_API_KEY=your-proxy-api-key

# Upstash Redis（可选，用于 ENABLE_GLOBAL_ROUND_ROBIN 时的 Key 轮询）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AI Gateway（可选，Cloudflare）
CLOUDFLARE_ACCOUNT_ID=
AI_GATEWAY_NAME=
CF_AIG_TOKEN=

# Provider API Keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
# ... 其他按需配置

# 配置
DEV=false
DEFAULT_MODEL=
ENABLE_GLOBAL_ROUND_ROBIN=false
