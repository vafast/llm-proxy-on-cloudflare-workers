# 复制为 .env.development 或 .env.production 后填写

# 代理鉴权（无 DB 时必填，有 DB 时可选，可与 Admin 创建的 key 二选一）
PROXY_API_KEY=

# Admin Key 管理（可选，用于 /admin/keys 鉴权）
ADMIN_KEY=

# 数据库（可选，用于 keys 表）
DATABASE_URL=

# Redis（可选，用于 ENABLE_GLOBAL_ROUND_ROBIN 时的 Key 轮询）
REDIS_URL=

# Provider API Keys — 海外（按需配置）
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
CEREBRAS_API_KEY=
COHERE_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
PERPLEXITYAI_API_KEY=
REPLICATE_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
OLLAMA_API_KEY=

# Provider API Keys — 中国（按需配置）
ARK_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
MINIMAX_API_KEY=
MOONSHOT_API_KEY=
QWEN_API_KEY=

# 自定义 OpenAI 兼容端点（JSON 字符串，可选）
CUSTOM_OPENAI_ENDPOINTS=

# 配置
PORT=8787
DEV=false
DEFAULT_MODEL=
ENABLE_GLOBAL_ROUND_ROBIN=false
