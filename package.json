{
  "name": "llm-proxy",
  "description": "通用 LLM API 代理，支持多厂商统一鉴权与 Key 轮询。可部署至 Node.js、Docker、Railway 等。",
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "PORT=8787 dotenvx run -f .env.development -- tsx watch src/index.ts",
    "build": "tsdown && cp .env.production dist/.env 2>/dev/null || true",
    "start": "PORT=8787 dotenvx run -f ./dist/.env -- node ./dist/index.mjs",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test-watch": "vitest watch",
    "test:integration": "./test/integration/api-http.sh",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.41.0",
    "@vafast/cors": "^0.1.3",
    "@vafast/request-id": "^0.1.1",
    "envalid": "^8.1.1",
    "ioredis": "^5.6.1",
    "pg": "^8.19.0",
    "vafast": "^0.7.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/pg": "^8.18.0",
    "eslint": "^9.39.2",
    "tsdown": "^0.21.0-beta.2",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
